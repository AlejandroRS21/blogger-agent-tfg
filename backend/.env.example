# ── PRIMARIO: VLLM en Modal (Qwen 2.5 7B) ──────────────────
# Desplegar con: modal deploy backend/modal_vllm_deploy.py
VLLM_ENDPOINT=https://your-app--vllm-qwen25-7b.modal.run
VLLM_API_KEY=sk-local

# ── Alternativas gratuitas ────────────────────────────────────
# HuggingFace Inference API (gratis)
HF_TOKEN=your_huggingface_token_here
# Google Gemini (capa gratuita disponible)
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ── Alternativas de pago ──────────────────────────────────────
# OpenAI (pago, solo modo explícito provider='openai')
OPENAI_API_KEY=your_openai_api_key_here
# Anthropic (no usado actualmente)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Modal ─────────────────────────────────────────────────────
MODAL_TOKEN_ID=your_modal_token_id_here
MODAL_TOKEN_SECRET=your_modal_token_secret_here

# ── APIs auxiliares ───────────────────────────────────────────
BRAVE_API_KEY=your_brave_api_key_here

# ── Configuración general ─────────────────────────────────────
VERBOSE=true
